# ==========================================
# TripDekho Enterprise Backend Environment
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/tripdekho"

# Redis Cache & Rate Limiting
REDIS_URL="redis://localhost:6379"

# RabbitMQ (Event Bus)
RABBITMQ_URL="amqp://admin:password@localhost:5672"

# Temporal (Workflow Engine)
TEMPORAL_ADDRESS="localhost:7233"

# Authentication & Security
JWT_SECRET="generate-a-strong-256-bit-secret-here"
JWT_EXPIRES_IN="30d"
ENCRYPTION_KEY="32-byte-encryption-key-hex-string" # For PII Data

# External Services (KYC, Payments)
RAZORPAY_KEY_ID="rzp_test_yourkeyid"
RAZORPAY_KEY_SECRET="rzp_test_yoursecret"
GST_API_KEY="masters_india_or_cleartax_api_key"

# Observability (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"

# AI Integration
OPENAI_API_KEY="sk-your-openai-api-key"

# Cloud Storage (Cloudinary / AWS)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Notifications (Email/SMS)
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT="2525"
EMAIL_USER="your-email-user"
EMAIL_PASS="your-email-password"
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="+1234567890"
META_WHATSAPP_TOKEN="your-meta-whatsapp-token"
META_WHATSAPP_PHONE_ID="your-meta-whatsapp-phone-id"
